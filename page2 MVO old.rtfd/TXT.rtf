  </div>\
</div>\
\
<script>\
(function() \{\
  var state = \{ posted: null, blocker: null, history: null, business: null, name: '' \};\
  var currentStep = 0;\
  var totalSteps = 4;\
\
  function updateDots(step) \{\
    for (var i = 0; i < totalSteps; i++) \{\
      var dot = document.getElementById('p2-dot-' + i);\
      dot.className = 'wiz-dot';\
      if (i < step) dot.className = 'wiz-dot done';\
      if (i === step) dot.className = 'wiz-dot active';\
    \}\
  \}\
\
  function showScreen(id) \{\
    var screens = document.querySelectorAll('#p2-wizard .wiz-screen');\
    for (var i = 0; i < screens.length; i++) \{\
      screens[i].classList.remove('active');\
    \}\
    var target = document.getElementById(id);\
    if (target) \{\
      target.classList.add('active');\
      target.style.animation = 'none';\
      target.offsetHeight;\
      target.style.animation = '';\
    \}\
  \}\
\
  function autoAdvance(card, key, value) \{\
    state[key] = value;\
    card.classList.add('selecting');\
    setTimeout(function() \{\
      card.classList.remove('selecting');\
      if (key === 'posted') \{\
        currentStep = 1;\
        updateDots(1);\
        showScreen(value === 'no' ? 'p2-q2a' : 'p2-q2b');\
      \} else if (key === 'blocker' || key === 'history') \{\
        currentStep = 2;\
        updateDots(2);\
        showScreen('p2-q3');\
      \} else if (key === 'business') \{\
        currentStep = 3;\
        updateDots(3);\
        showScreen('p2-q4');\
        setTimeout(function() \{\
          document.getElementById('p2-name').focus();\
        \}, 400);\
      \}\
    \}, 280);\
  \}\
\
  function buildScript() \{\
    var name = document.getElementById('p2-name').value.trim();\
    if (!name) \{\
      var inp = document.getElementById('p2-name');\
      inp.style.borderColor = '#2dd4bf';\
      inp.focus();\
      return;\
    \}\
    state.name = name;\
    showScreen('p2-loading');\
\
    // Stagger epiphany bridge lines\
    var ep1 = document.getElementById('p2-ep-1');\
    var ep2 = document.getElementById('p2-ep-2');\
    var ep3 = document.getElementById('p2-ep-3');\
    setTimeout(function() \{ if (ep1) ep1.classList.add('visible'); \}, 300);\
    setTimeout(function() \{ if (ep2) ep2.classList.add('visible'); \}, 900);\
    setTimeout(function() \{ if (ep3) ep3.classList.add('visible'); \}, 1500);\
\
    setTimeout(function() \{\
      var display = name.charAt(0).toUpperCase() + name.slice(1).toLowerCase();\
      document.getElementById('p2-display-name').textContent = display + "'s";\
      document.getElementById('p2-script-name').textContent = display;\
\
      // Build personalized script line 2 based on answers\
      var line2 = '';\
      var posted = state.posted;\
      var blocker = state.blocker;\
      var history = state.history;\
      var biz = state.business;\
\
      if (posted === 'no' && blocker === 'camera') \{\
        line2 = "I\\'ve been avoiding this for a while because honestly, I don\\'t love how I come across on camera. I watch myself back and all I see is everything I\\'d change. But I realized the version of me I\\'m waiting to become is never going to show up unless this version goes first. So this is me, exactly as I am right now, doing the thing I\\'ve been putting off because I was waiting to feel ready. I don\\'t feel ready. But I\\'m here, and I think that counts for something.";\
      \} else if (posted === 'no' && blocker === 'ideas') \{\
        line2 = "The thing that\\'s been stopping me is not confidence or cameras or any of the stuff people usually talk about. It\\'s simpler than that. I genuinely didn\\'t know what to say. I\\'d think about making a video and go completely blank, like everything I know just disappears the second I think about hitting record. But I found something that helped me get past that, and this is the result. It\\'s not perfect, but it\\'s real, and it\\'s the first thing I\\'ve actually been able to say on camera that sounds like me.";\
      \} else if (posted === 'no' && (blocker === 'nothing' || blocker === 'procrastinating')) \{\
        line2 = "I\\'ve been meaning to start this for a while now, and I kept telling myself I\\'d do it when the timing was better, when I had more figured out, when I felt like I actually had something worth saying. But at some point you have to stop planning and just start, and that\\'s what this is. This is me starting. I don\\'t have it all figured out, and I\\'m not going to pretend that I do, but I have something real to say and I think that matters more than having the perfect setup or the perfect script or the perfect anything.";\
      \} else if (posted === 'yes' && history === 'was') \{\
        line2 = "I used to post pretty consistently, and honestly, it was going well. Then something happened, life got in the way, I lost the rhythm, and I just never came back. It\\'s been sitting in the back of my mind ever since, this feeling like I abandoned something that was actually working. So this is me coming back. Not with some big relaunch or a brand overhaul, just me picking up where I left off and doing the thing I already know I\\'m capable of doing.";\
      \} else if (posted === 'yes' && (history === 'few' || history === 'stops')) \{\
        line2 = "I\\'ve posted before, but if I\\'m being honest it never really stuck. I\\'d make a video, maybe two, feel weird about it, and quietly stop. The pattern kept repeating and I kept telling myself next time would be different. But nothing changes until you actually change what you\\'re doing, so I\\'m trying something new this time. I have a system, I have a plan, and I\\'m not doing this alone anymore. That\\'s what this is. Day one, take one, and this time I\\'m finishing what I start.";\
      \} else \{\
        line2 = "I\\'ve been thinking about posting for a while now, and I kept telling myself I\\'d wait until I felt more ready, until I had better equipment, until I knew exactly what I was doing. But at some point you have to stop planning and just start, and that\\'s what this is. This is me starting. I don\\'t have it all figured out, and I\\'m not going to pretend that I do, but I have something real to say and I think that matters more than having the perfect setup or the perfect script or the perfect anything.";\
      \}\
      document.getElementById('p2-script-line-2').textContent = line2;\
\
      showScreen('p2-result');\
\
      setTimeout(function() \{\
        var gotov2 = document.getElementById('p2-goto-v2');\
        if (gotov2) \{\
          gotov2.scrollIntoView(\{ behavior: 'smooth', block: 'center' \});\
        \}\
      \}, 400);\
    \}, 1800);\
  \}\
\
  // Copy script button\
  document.getElementById('p2-copy-btn').addEventListener('click', function() \{\
    var btn = this;\
    var lines = [];\
    var el1 = document.getElementById('p2-script-line-1');\
    var el2 = document.getElementById('p2-script-line-2');\
    if (el1) lines.push(el1.textContent.trim());\
    if (el2) lines.push(el2.textContent.trim());\
    var scriptText = lines.join('\\n\\n');\
    if (navigator.clipboard && scriptText) \{\
      navigator.clipboard.writeText(scriptText).then(function() \{\
        btn.textContent = 'Copied!';\
        btn.classList.add('copied');\
        setTimeout(function() \{\
          btn.textContent = 'Copy Script';\
          btn.classList.remove('copied');\
        \}, 2000);\
      \}).catch(function() \{\
        btn.textContent = 'Copy failed';\
        setTimeout(function() \{ btn.textContent = 'Copy Script'; \}, 2000);\
      \});\
    \}\
  \});\
\
  // Start Over button\
  document.getElementById('p2-start-over').addEventListener('click', function() \{\
    state = \{ posted: null, blocker: null, history: null, business: null \};\
    currentStep = 0;\
    updateDots(0);\
    document.getElementById('p2-name').value = '';\
    // Reset all choice cards\
    var cards = document.querySelectorAll('#p2-wizard .choice-card');\
    for (var i = 0; i < cards.length; i++) \{\
      cards[i].classList.remove('selecting', 'selected');\
    \}\
    // Reset epiphany bridge\
    var ep1 = document.getElementById('p2-ep-1');\
    var ep2 = document.getElementById('p2-ep-2');\
    var ep3 = document.getElementById('p2-ep-3');\
    if (ep1) ep1.classList.remove('visible');\
    if (ep2) ep2.classList.remove('visible');\
    if (ep3) ep3.classList.remove('visible');\
    showScreen('p2-q1');\
    window.scrollTo(\{ top: 0, behavior: 'smooth' \});\
  \});\
\
  function skipToName() \{\
    currentStep = 3;\
    updateDots(3);\
    showScreen('p2-q4');\
    setTimeout(function() \{\
      document.getElementById('p2-name').focus();\
    \}, 400);\
  \}\
\
  // Wire up choice cards\
  document.getElementById('p2-c-posted-no').addEventListener('click', function() \{ autoAdvance(this, 'posted', 'no'); \});\
  document.getElementById('p2-c-posted-yes').addEventListener('click', function() \{ autoAdvance(this, 'posted', 'yes'); \});\
\
  document.getElementById('p2-c-block-ideas').addEventListener('click', function() \{ autoAdvance(this, 'blocker', 'ideas'); \});\
  document.getElementById('p2-c-block-camera').addEventListener('click', function() \{ autoAdvance(this, 'blocker', 'camera'); \});\
  document.getElementById('p2-c-block-nothing').addEventListener('click', function() \{ autoAdvance(this, 'blocker', 'nothing'); \});\
  document.getElementById('p2-c-block-procrastinating').addEventListener('click', function() \{ autoAdvance(this, 'blocker', 'procrastinating'); \});\
\
  document.getElementById('p2-c-hist-few').addEventListener('click', function() \{ autoAdvance(this, 'history', 'few'); \});\
  document.getElementById('p2-c-hist-stops').addEventListener('click', function() \{ autoAdvance(this, 'history', 'stops'); \});\
  document.getElementById('p2-c-hist-was').addEventListener('click', function() \{ autoAdvance(this, 'history', 'was'); \});\
\
  document.getElementById('p2-c-biz-yes').addEventListener('click', function() \{ autoAdvance(this, 'business', 'yes'); \});\
  document.getElementById('p2-c-biz-building').addEventListener('click', function() \{ autoAdvance(this, 'business', 'building'); \});\
  document.getElementById('p2-c-biz-no').addEventListener('click', function() \{ autoAdvance(this, 'business', 'no'); \});\
\
  document.getElementById('p2-build').addEventListener('click', buildScript);\
  document.getElementById('p2-name').addEventListener('keypress', function(e) \{\
    if (e.key === 'Enter') buildScript();\
  \});\
  document.getElementById('p2-skip-q1').addEventListener('click', skipToName);\
\})();\
</script>}