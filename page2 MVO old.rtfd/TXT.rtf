            <div class="vt-status">&#x1F512;</div>\
          </div>\
          <div class="vt-item locked">\
            <div class="vt-label">Video 4</div>\
            <div class="vt-status">&#x1F512;</div>\
          </div>\
          <div class="vt-item locked">\
            <div class="vt-label">Video 5</div>\
            <div class="vt-status">&#x1F512;</div>\
          </div>\
          <div class="vt-item locked">\
            <div class="vt-label">Video 6</div>\
            <div class="vt-status">&#x1F512;</div>\
          </div>\
          <div class="vt-item locked">\
            <div class="vt-label">Video 7</div>\
            <div class="vt-status">&#x1F512;</div>\
          </div>\
